# ─── Frontend (Vite) ───────────────────────────────────────────────────────────
# Supabase project URL — tìm ở: Project Settings > API > Project URL
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon/public key — tìm ở: Project Settings > API > anon public
VITE_SUPABASE_ANON_KEY=<anon-key>

# ─── Scripts Node.js (migration / seeding) ─────────────────────────────────────
# Supabase service_role key — tìm ở: Project Settings > API > service_role (secret)
# ⚠️  KHÔNG commit key này — chỉ dùng cho scripts chạy local
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
